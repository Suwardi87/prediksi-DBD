        <!-- Note -->
        <mxCell id="note" value="Aktor: Petugas&#xa;Algoritma: Random Forest (25 pohon, entropy, m=2)&#xa;Fitur: Usia, Lama Rawat Inap, Jenis Kelamin&#xa;Label: Rendah(1), Sedang(2), Tinggi(3)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=10;align=left;spacingLeft=5" vertex="1" parent="1">

        <!-- S5: Export Laporan -->
        <mxCell id="s5" value="Export Laporan (PDF / Excel)&#xa;&#xa;entry / generate file export&#xa;do / format data ke PDF/Excel&#xa;exit / download file ke pengguna" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;spacingTop=5" vertex="1" parent="1">

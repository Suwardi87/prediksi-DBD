        <mxCell id="initial" value="" style="ellipse;fillColor=#000000;strokeColor=#000000" vertex="1" parent="1">
          <mxGeometry x="530" y="90" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- S1: Halaman Laporan Ditampilkan -->
        <mxCell id="s1" value="Halaman Laporan Ditampilkan&#xa;&#xa;entry / load daftar tahun dari DB&#xa;do / tampilkan halaman laporan&#xa;       dengan filter default" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=top;spacingTop=5" vertex="1" parent="1">

          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- S3: Query & Hitung Statistik -->
        <mxCell id="s3" value="Query &amp; Hitung Statistik&#xa;&#xa;entry / query kasus_bulanan / pasien_dbd&#xa;do / hitung total kasus, rata-rata,&#xa;       kasus tertinggi, kasus terendah&#xa;exit / siapkan data untuk grafik" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;verticalAlign=top;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="400" y="460" width="290" height="105" as="geometry" />

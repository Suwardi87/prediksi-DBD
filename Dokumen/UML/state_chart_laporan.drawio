          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- S4: Tampilkan Grafik & Tabel -->
        <mxCell id="s4" value="Tampilkan Grafik &amp; Tabel Laporan&#xa;&#xa;entry / render grafik (Chart.js)&#xa;do / tampilkan tabel detail data,&#xa;       statistik ringkasan,&#xa;       grafik batang / line" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;verticalAlign=top;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="400" y="620" width="290" height="105" as="geometry" />
